# Template de configuration DEV — copier vers .env.dev :
#   cp .env.dev.example .env.dev
# Valeurs de dev par défaut (non secrètes), prêtes à l'emploi avec docker-compose.dev.yml.

# Base de données — lue par l'API
DB_HOST=db
DB_PORT=3306
DB_USER=monitor
DB_PASSWORD=monitor
DB_NAME=monitor

# Initialisation du conteneur MySQL
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=monitor
MYSQL_USER=monitor
MYSQL_PASSWORD=monitor

# Auth — en dev (DEBUG=true) une clé courte est tolérée ; en prod elle doit faire ≥ 32 car.
SECRET_KEY=dev-secret-key
# Emails admin séparés par des virgules
ADMIN_EMAILS=admin@example.com

# Mail (MailPit en dev — UI sur http://localhost:8025)
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@gotyeah.local

# Base des liens dans les emails
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:8000
