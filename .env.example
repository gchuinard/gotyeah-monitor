# Template de configuration PROD — copier vers .env et remplir les vraies valeurs.
#   cp .env.example .env
# Ne jamais committer le .env réel (il est gitignoré).

# --- Backend (FastAPI) ---
# OBLIGATOIRE, minimum 32 caractères. L'API refuse de démarrer en prod sinon.
# Générer avec : python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# --- Base de données (lue par l'API) ---
# DB_HOST est forcé à "db" par docker-compose.prod.yml (nom du service réseau).
DB_USER=gotyeah_user
DB_PASSWORD=change-me-db-password
DB_HOST=db
DB_PORT=3306
DB_NAME=gotyeah

# --- Initialisation du conteneur MySQL ---
# docker-compose.prod.yml dérive MYSQL_DATABASE/USER/PASSWORD des DB_* ci-dessus ;
# seul le mot de passe root doit être fourni ici.
MYSQL_ROOT_PASSWORD=change-me-root-password

# --- Frontend (injecté à la build de l'image front) ---
VITE_API_URL=https://api.votre-domaine.com

# --- Admin (emails séparés par des virgules ; sensible à la casse) ---
ADMIN_EMAILS=

# --- Mail (SMTP réel, ex. Resend) ---
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=
SMTP_FROM=noreply@votre-domaine.com

# URL publique du frontend, utilisée dans les liens des emails (sans / final).
# Sert aussi de cible de redirection après connexion OIDC.
FRONTEND_URL=https://votre-domaine.com

# --- OIDC / SSO (bouton « Se connecter avec Pocket ID », optionnel) ---
# Renseigner les 4 valeurs pour activer le bouton ; laisser vide pour le masquer.
# Le client se crée dans Pocket ID (idp.gautierchuinard.com) avec le redirect_uri ci-dessous.
OIDC_ISSUER=https://idp.gautierchuinard.com
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=https://api.votre-domaine.com/auth/oidc/callback
# Créer un compte Monitor à la première connexion OIDC (true) ou n'autoriser que les
# emails ayant déjà un compte (false). Pocket ID n'a pas d'inscription ouverte, donc
# seuls les comptes que TU y crées peuvent se connecter.
OIDC_ALLOW_SIGNUP=true
# Libellé du bouton (optionnel).
OIDC_BUTTON_LABEL=Se connecter avec Pocket ID
