FROM node:24-alpine

WORKDIR /app

# Installer les dépendances (npm ci = reproductible depuis le lockfile, comme la CI)
COPY package*.json ./
RUN npm ci

# Copier le code
COPY . .

# VITE_* vars must be available at build time
ARG VITE_API_URL
ENV VITE_API_URL=$VITE_API_URL

# Build SvelteKit
RUN npm run build

EXPOSE 80

# Lancer le serveur de prévisualisation en prod
CMD ["npm", "run", "preview", "--", "--host", "0.0.0.0", "--port", "80"]